{
  "expo": {
    "name": "XCollection",
    "slug": "xcollection",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/XC.png",
    "scheme": "xcollection",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.xunifire.xcollection"
    },
    "android": {
      "package": "com.xunifire.xcollection",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/XC.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/XC.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
